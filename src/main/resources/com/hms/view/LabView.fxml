<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hms.controller.LabController"
      spacing="16">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Lab Tests" styleClass="page-title"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField"
                   promptText="Search by patient or test name..."
                   prefWidth="260"
                   onKeyReleased="#handleSearch"/>
        <Button text="+ Order Lab Test"
                onAction="#handleAdd"
                styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="labTable"
               VBox.vgrow="ALWAYS">
        <placeholder>
            <Label text="No tests found." />
        </placeholder>
        <columns>
            <TableColumn fx:id="colId"      text="ID"       prefWidth="50"/>
            <TableColumn fx:id="colApptId"  text="Appt ID"  prefWidth="70"/>
            <TableColumn fx:id="colPatient" text="Patient"  prefWidth="150"/>
            <TableColumn fx:id="colTest"    text="Test"     prefWidth="150"/>
            <TableColumn fx:id="colResult"  text="Result"   prefWidth="150"/>
            <TableColumn fx:id="colStatus"  text="Status"   prefWidth="90"/>
            <TableColumn fx:id="colActions" text="Actions"  prefWidth="170"/>
        </columns>
    </TableView>

</VBox>