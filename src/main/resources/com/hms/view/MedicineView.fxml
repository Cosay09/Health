<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hms.controller.MedicineController"
      spacing="16">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Medicine Inventory" styleClass="page-title"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <!-- Low stock warning label — hidden until needed -->
        <Label fx:id="lowStockWarning"
               styleClass="low-stock-warning"
               visible="false"/>
        <TextField fx:id="searchField"
                   promptText="Search medicine..."
                   prefWidth="220"
                   onKeyReleased="#handleSearch"/>
        <Button text="+ Add Medicine"
                onAction="#handleAdd"
                styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="medicineTable"
               VBox.vgrow="ALWAYS">
        <placeholder>
            <Label text="No medicine found." />
        </placeholder>

        <columns>
            <TableColumn fx:id="colId"     text="ID"     prefWidth="50"/>
            <TableColumn fx:id="colName"   text="Name"   prefWidth="180"/>
            <TableColumn fx:id="colStock"  text="Stock"  prefWidth="80"/>
            <TableColumn fx:id="colUnit"   text="Unit"   prefWidth="80"/>
            <TableColumn fx:id="colPrice"  text="Price"  prefWidth="90"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="160"/>
        </columns>
    </TableView>

</VBox>